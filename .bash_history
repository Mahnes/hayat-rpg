#!/data/data/com.termux/files/usr/bin/bash
clear
echo "=== Ultra İndirici ⚡ ==="
echo ""
echo "1) Tam video indir"
echo "2) Ultra hızlı kesit indir"
echo "3) Sadece ses (MP3)"
echo "4) Video kapağını indir"
echo "5) Videodan ekran görüntüsü al (HD ⚡)"
echo "6) Çoklu kesit al ve birleştir 🔥"
echo "7) Çoklu kesit (SHORTS 9:16) 🔥📱"
echo ""
read -p "Seçim: " secim
echo ""
read -p "Link: " link
# YouTube kontrolü
if [[ "$link" == *"youtube.com"* || "$link" == *"youtu.be"* ]]; then     YT=true; else     YT=false; fi
# -------------------------
# KALİTE
if [[ "$secim" = "1" || "$secim" = "2" || "$secim" = "6" || "$secim" = "7" ]]; then     if $YT; then         echo "";         echo "Kalite seç:";         echo "1) 1080p";         echo "2) 720p";         echo "3) 480p";         read -p "Seçim: " kalite;          if [ "$kalite" = "1" ]; then             FORMAT="bestvideo[height<=1080]+bestaudio/best";         elif [ "$kalite" = "2" ]; then             FORMAT="bestvideo[height<=720]+bestaudio/best";         else             FORMAT="bestvideo[height<=480]+bestaudio/best";         fi;     else         FORMAT="best";     fi; fi
# -------------------------
# 6 NORMAL ÇOKLU KESİT
if [ "$secim" = "6" ]; then     TMP_DIR="/sdcard/Download/temp_kesitler";     mkdir -p "$TMP_DIR";     rm -f $TMP_DIR/*;      LIST_FILE="$TMP_DIR/list.txt";     > "$LIST_FILE";      index=1;      echo "";     echo "Kesitleri gir (Enter ile bitir)";      while true; do         read -p "Başlangıç: " bas;         [ -z "$bas" ] && break;         read -p "Bitiş: " bit;         [ -z "$bit" ] && break;          echo "Kesit $index indiriliyor...";          yt-dlp         --js-runtimes node         --remote-components ejs:github         -f "$FORMAT"         --download-sections "*$bas-$bit"         --merge-output-format mp4         -o "$TMP_DIR/part$index.mp4" "$link";          echo "file '$TMP_DIR/part$index.mp4'" >> "$LIST_FILE";         ((index++));     done;      ffmpeg -loglevel error -f concat -safe 0 -i "$LIST_FILE"     -c:v libx264 -c:a aac "/sdcard/Download/birlesmis_video.mp4";      rm -rf "$TMP_DIR";      echo "Hazır ✔"; 
elif [ "$secim" = "7" ]; then     TMP_DIR="/sdcard/Download/temp_shorts";     mkdir -p "$TMP_DIR";     rm -f $TMP_DIR/*;      LIST_FILE="$TMP_DIR/list.txt";     > "$LIST_FILE";      index=1;      echo "";     echo "Shorts kesitleri gir (Enter ile bitir)";      while true; do         read -p "Başlangıç: " bas;         [ -z "$bas" ] && break;         read -p "Bitiş: " bit;         [ -z "$bit" ] && break;          echo "Kesit $index indiriliyor (Shorts)...";          yt-dlp         --js-runtimes node         --remote-components ejs:github         -f "$FORMAT"         --download-sections "*$bas-$bit"         --merge-output-format mp4         -o "$TMP_DIR/raw$index.mp4" "$link"; 
        ffmpeg -loglevel error -i "$TMP_DIR/raw$index.mp4"         -vf "crop=ih*9/16:ih:(iw-ih*9/16)/2:0,scale=720:1280"         -c:v libx264 -c:a aac "$TMP_DIR/part$index.mp4";          rm "$TMP_DIR/raw$index.mp4";          echo "file '$TMP_DIR/part$index.mp4'" >> "$LIST_FILE";          ((index++));     done; 
    OUTPUT_DIR="/sdcard/Download";     BASENAME="shorts_video";     EXT="mp4";     i=1;     while [ -f "$OUTPUT_DIR/${BASENAME}_${i}.$EXT" ]; do         ((i++));     done;     OUTPUT_FILE="$OUTPUT_DIR/${BASENAME}_${i}.$EXT";      ffmpeg -loglevel error -f concat -safe 0 -i "$LIST_FILE"     -c:v libx264 -c:a aac "$OUTPUT_FILE";      rm -rf "$TMP_DIR";      echo "Shorts hazır ✔ → $OUTPUT_FILE"; 
elif [ "$secim" = "2" ]; then     read -p "Başlangıç: " bas;     read -p "Bitiş: " bit;      yt-dlp     --js-runtimes node     --remote-components ejs:github     -f "$FORMAT"     --download-sections "*$bas-$bit"     --merge-output-format mp4     -o "/sdcard/Download/kesit.mp4" "$link";      echo "Kesit hazır ✔"; 
elif [ "$secim" = "1" ]; then     yt-dlp     --js-runtimes node     --remote-components ejs:github     -f "$FORMAT"     --merge-output-format mp4     -o "/sdcard/Download/%(title)s.%(ext)s" "$link";      echo "Video indirildi ✔"; 
elif [ "$secim" = "3" ]; then     yt-dlp -x --audio-format mp3     -o "/sdcard/Download/%(title)s.%(ext)s" "$link";      echo "Ses indirildi ✔"; 
elif [ "$secim" = "4" ]; then     yt-dlp --skip-download --write-thumbnail     -o "/sdcard/Download/%(title)s.%(ext)s" "$link";      echo "Kapak indirildi ✔"; 
elif [ "$secim" = "5" ]; then     read -p "Zaman: " zaman;      yt-dlp     --js-runtimes node     --remote-components ejs:github     -f "bestvideo"     --download-sections "*$zaman-$zaman"     -o "/sdcard/Download/tmp.mp4" "$link";      ffmpeg -loglevel error -i "/sdcard/Download/tmp.mp4"     -frames:v 1 -q:v 1 "/sdcard/Download/screenshot.jpg";      rm "/sdcard/Download/tmp.mp4";      echo "Screenshot hazır ✔";  else     echo "Hatalı seçim!"; fi
echo ""
read -p "Çıkmak için Enter..."
rm $PREFIX/bin/indir
